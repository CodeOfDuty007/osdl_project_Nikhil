<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotelos.gui.MainController" style="-fx-background-color: #D7CCC8; -fx-font-family: 'Segoe UI', sans-serif;">
    <top>
        <VBox>
            <HBox alignment="CENTER" style="-fx-background-color: #3E2723; -fx-padding: 20px;">
                <Label text="Grand Hotel Management System" style="-fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 26px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 2);" />
            </HBox>
            <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #5D4037; -fx-padding: 12px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);">
                <Button fx:id="navHome" text="Dashboard Center" onAction="#navHome" style="-fx-background-color: transparent; -fx-text-fill: #EFEBE9; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
                <Button fx:id="navAddRoom" text="Add New Room" onAction="#navAddRoom" style="-fx-background-color: transparent; -fx-text-fill: #EFEBE9; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
                <Button fx:id="navBookRoom" text="Book a Room" onAction="#navBookRoom" style="-fx-background-color: transparent; -fx-text-fill: #EFEBE9; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
                <Button fx:id="navCheckout" text="Guest Checkout" onAction="#navCheckout" style="-fx-background-color: transparent; -fx-text-fill: #EFEBE9; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
                <Button fx:id="navAmenities" text="Amenities &amp; Services" onAction="#navAmenities" style="-fx-background-color: transparent; -fx-text-fill: #EFEBE9; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
                
                <Region HBox.hgrow="ALWAYS" /> <!-- Push save to right -->
                
                <Button fx:id="btnSaveData" mnemonicParsing="false" onAction="#handleSaveData" text="Save &amp; Sync DB" style="-fx-background-color: #A1887F; -fx-text-fill: #3E2723; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 6; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="mainContentStack" style="-fx-padding: 30px;">
            
            <!-- 1. HOME VIEW (Table) -->
            <VBox fx:id="homeView" spacing="15.0" style="-fx-background-color: #EFEBE9; -fx-padding: 25px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 8);">
                <Label text="Current Room Status Overview" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4E342E;"/>
                <TableView fx:id="roomTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8F5F2; -fx-border-color: #A1887F; -fx-border-width: 1px; -fx-border-radius: 5px;">
                    <columns>
                      <TableColumn fx:id="roomNoCol" text="Room No." />
                      <TableColumn fx:id="roomTypeCol" text="Type Architecture" />
                      <TableColumn fx:id="priceCol" text="Price/Night ($)" />
                      <TableColumn fx:id="availCol" text="Availability Status" />
                      <TableColumn fx:id="amenitiesCol" text="Amenities" />
                    </columns>
                </TableView>
            </VBox>

            <!-- 2. ADD ROOM VIEW -->
            <VBox fx:id="addRoomView" visible="false" spacing="25.0" alignment="TOP_CENTER" style="-fx-background-color: #EFEBE9; -fx-padding: 50px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 8);">
                <Label text="Add New Room Integration" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #3E2723;"/>
                <Label text="Configure the parameters below to add room capacity into the management suite." style="-fx-text-fill: #795548; -fx-font-size: 14px;"/>
                
                <GridPane hgap="25" vgap="25" alignment="CENTER" style="-fx-padding: 20px 0;">
                    <Label text="Room Number Identifier:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                    <TextField fx:id="txtAddRoomNo" promptText="e.g., 401" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-padding: 10; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4; -fx-font-size: 14px;"/>
                    
                    <Label text="Room Type Definition:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                    <ComboBox fx:id="comboAddRoomType" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-padding: 8; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4;"/>
                </GridPane>
                
                <Button text="Systemize &amp; Create Room" onAction="#submitAddRoom" style="-fx-background-color: #8D6E63; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-background-radius: 6; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
            </VBox>

            <!-- 3. BOOK ROOM VIEW -->
            <VBox fx:id="bookRoomView" visible="false" spacing="25.0" alignment="TOP_CENTER" style="-fx-background-color: #EFEBE9; -fx-padding: 50px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 8);">
                <Label text="Client Booking Portal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #3E2723;"/>
                
                <HBox alignment="CENTER" spacing="15" style="-fx-background-color: #D7CCC8; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label text="Select Available Room:" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                    <ComboBox fx:id="comboBookRoomSelect" style="-fx-pref-width: 350; -fx-padding: 8; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4;" />
                </HBox>
                
                <HBox alignment="CENTER" spacing="30" style="-fx-padding: 10;">
                    <!-- Dynamically updated image node -->
                    <ImageView fx:id="roomImagePreview" fitWidth="320" fitHeight="200" preserveRatio="false" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 4);" />
                    
                    <GridPane hgap="25" vgap="25" alignment="CENTER">
                        <Label text="Primary Guest Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                        <TextField fx:id="txtGuestName" promptText="Full Legal Name" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-padding: 10; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4; -fx-font-size: 14px;"/>
                        
                        <Label text="Contact Number:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                        <TextField fx:id="txtGuestContact" promptText="(123) 456-7890" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-padding: 10; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4; -fx-font-size: 14px;"/>

                        <Label text="Duration (Days):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                        <TextField fx:id="txtGuestDays" promptText="Length of stay" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-padding: 10; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4; -fx-font-size: 14px;"/>
                    </GridPane>
                </HBox>
                
                <Button text="Confirm Secure Booking" onAction="#submitBooking" style="-fx-background-color: #5D4037; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-background-radius: 6; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
            </VBox>

            <!-- 4. CHECKOUT VIEW -->
            <VBox fx:id="checkoutView" visible="false" spacing="25.0" alignment="TOP_CENTER" style="-fx-background-color: #EFEBE9; -fx-padding: 50px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 8);">
                <Label text="Checkout &amp; Billing Resolution" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #3E2723;"/>
                
                <HBox alignment="CENTER" spacing="15" style="-fx-background-color: #D7CCC8; -fx-padding: 15; -fx-background-radius: 8;">
                    <Label text="Target Booked Room:" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 15px;"/>
                    <ComboBox fx:id="comboCheckoutRoom" style="-fx-pref-width: 350; -fx-padding: 8; -fx-background-color: #FFFFFF; -fx-border-color: #A1887F; -fx-border-radius: 4;" />
                </HBox>
                
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 30; -fx-background-color: #D7CCC8; -fx-border-color: #A1887F; -fx-border-radius: 6; -fx-max-width: 600;">
                    <Label text="Notice:" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="Upon checkout, the generic billing calculator will assess the room tariff," style="-fx-text-fill: #3E2723; -fx-font-size: 14px;"/>
                    <Label text="apply corporate discounts, notify room clean-up services automatically via threads," style="-fx-text-fill: #3E2723; -fx-font-size: 14px;"/>
                    <Label text="and generate a serialized text receipt physically for auditing." style="-fx-text-fill: #3E2723; -fx-font-size: 14px;"/>
                </VBox>
                
                <Button text="Execute Checkout Sequence" onAction="#submitCheckout" style="-fx-background-color: #4E342E; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-background-radius: 6; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
            </VBox>
            
            <!-- 5. AMENITIES VIEW -->
            <VBox fx:id="amenitiesView" visible="false" spacing="35.0" alignment="TOP_CENTER" style="-fx-background-color: #EFEBE9; -fx-padding: 50px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 8);">
                <Label text="Hotel Amenities &amp; Services" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3E2723;"/>
                <Label text="Enjoy our world-class facilities designed exceptionally for your comfort." style="-fx-text-fill: #795548; -fx-font-size: 16px;"/>

                <GridPane hgap="60" vgap="25" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #FFFFFF; -fx-border-color: #D7CCC8; -fx-border-radius: 8; -fx-background-radius: 8;">
                    <!-- Column 1 -->
                    <Label text="✓  Computimentary High-Speed Wi-Fi" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  24/7 Premium Room Service" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  Fully Equipped Fitness Center" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  In-Room Mini Bar &amp; Fridge" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    
                    <!-- Column 2 -->
                    <Label text="✓  Olympic-Sized Swimming Pool" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  Continental Breakfast Buffet" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  Luxury Spa &amp; Wellness Center" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                    <Label text="✓  Valet Parking &amp; Chauffeur" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #4E342E; -fx-font-size: 16px;"/>
                </GridPane>
            </VBox>
            
        </StackPane>
    </center>
</BorderPane>
